# Ignore workspace state (local UI layout/history) for all vaults
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Ignore Obsidian cache files
.obsidian/graph.json
.obsidian/cache

# Ignore all top-level Obsidian config (app.json, appearance.json,
# community-plugins.json, core-plugins.json, copilot-index-*.json, etc.)
# Keep per-machine settings local rather than syncing via git.
.obsidian/*.json

# Ignore all plugin binaries/data by default
.obsidian/plugins/*

# Optionally: keep plugin folder structure (but ignore plugin contents)
!.obsidian/plugins/
.obsidian/plugins/*/main.js
.obsidian/plugins/*/manifest.json

# OS-specific files
.DS_Store
Thumbs.db

# Common build artifacts (in case you keep Node/Python projects in a vault)
node_modules/
venv/
dist/

# Optional: ignore secrets
.env
.env.*

